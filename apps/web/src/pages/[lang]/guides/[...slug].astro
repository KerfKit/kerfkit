---
// L-3: /{lang}/guides/{yerel-slug} — yalnız reviewed:true sayfalar üretilir (docs/18 §5.2).
import '../../../../styles/tokens.css';
import { getCollection, render } from 'astro:content';
import { siteDict, guideUrl, liteUrl } from '../../../i18n/site';

export async function getStaticPaths() {
  const guides = await getCollection('guides', (g) => g.data.reviewed && g.id.includes('/'));
  return guides.map((g) => {
    const clean = g.id.replace(/\.md$/, '');
    const [lang, ...rest] = clean.split('/');
    return { params: { lang, slug: rest.join('/') }, props: { g, lang } };
  });
}
const { g, lang } = Astro.props;
const { Content } = await render(g);
const t = siteDict[lang] ?? siteDict.en;

// Aynı `key`li onaylı dil sürümleri → hreflang
const all = await getCollection('guides', (e) => e.data.reviewed && e.data.key === g.data.key);
const alternates = all.map((e) => {
  const clean = e.id.replace(/\.md$/, '');
  const lang = clean.includes('/') ? clean.split('/')[0] : 'en';
  const slug = clean.includes('/') ? clean.split('/').slice(1).join('/') : clean;
  return { lang, href: `https://kerfkit.app${guideUrl(lang, slug)}` };
});
const xDefault = alternates.find((a) => a.lang === 'en')?.href;
---

<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{g.data.title} — kerfkit</title>
  <meta name="description" content={g.data.description} />
  {alternates.map((a) => <link rel="alternate" hreflang={a.lang} href={a.href} />)}
  {xDefault && <link rel="alternate" hreflang="x-default" href={xDefault} />}
</head>
<body>

<header class="kabuk">
  <a class="marka" href="/">
    <svg viewBox="0 0 1024 1024" width="28" height="28" aria-hidden="true"><rect width="1024" height="1024" fill="var(--color-timber-900)" rx="230"/><g fill="var(--color-amber-500)" transform="rotate(-45 512 512)"><rect x="-300" y="342" width="788" height="340"/><rect x="536" y="342" width="788" height="340"/></g></svg>
    <span>kerfkit</span>
  </a>
  <a class="cta cta-sm" href={liteUrl(lang)}>{t.calcCta}</a>
</header>

<main>
  <div class="serit">
    {t.stripA}
    <a href={liteUrl(lang)}>{t.stripCalc}</a> · <a href="/#founding">{t.stripFound}</a>
  </div>
  <article>
    <h1>{g.data.title}</h1>
    <Content />
  </article>
</main>

<footer class="kabuk alt">
  <span>© 2026 kerfkit · <a href="/">{t.footHome}</a> · <a href={liteUrl(lang)}>{t.footCalc}</a></span>
</footer>

<style is:global>
  * { box-sizing: border-box; margin: 0; }
  body { background: var(--color-timber-950); color: var(--color-timber-200);
         font: 17px/1.7 -apple-system, "SF Pro Text", "Segoe UI", sans-serif; }
  main { max-width: 720px; margin: 0 auto; padding: 24px 24px 80px; }
  .kabuk { display: flex; justify-content: space-between; align-items: center;
           padding: 16px 24px; max-width: 1080px; margin: 0 auto; }
  .marka { display: flex; align-items: center; gap: 10px; font-weight: 700;
           font-size: 22px; color: var(--color-timber-50); text-decoration: none; }
  .cta { display: inline-block; background: var(--color-amber-500); color: var(--color-timber-950);
         font-weight: 700; text-decoration: none; padding: 8px 16px; border-radius: 10px; font-size: 14px; }
  .serit { background: var(--color-timber-900); border-left: 3px solid var(--color-amber-500);
           border-radius: 10px; padding: 10px 14px; font-size: 14px; margin-top: 16px;
           color: var(--color-timber-300); }
  .serit a { color: var(--color-amber-400); }
  article h1 { color: var(--color-timber-50); font-size: 34px; line-height: 1.2; margin: 24px 0 8px; }
  article h2 { color: var(--color-timber-50); font-size: 24px; margin: 40px 0 12px; }
  article p { margin: 14px 0; }
  article a { color: var(--color-amber-400); }
  article li { margin: 8px 0 8px 20px; }
  article strong { color: var(--color-timber-50); }
  article table { border-collapse: collapse; margin: 16px 0; width: 100%; }
  article th, article td { border: 1px solid var(--color-timber-700);
    padding: 8px 12px; text-align: left; font-size: 15px; }
  article th { color: var(--color-timber-50); background: var(--color-timber-900); }
  footer.alt { color: var(--color-timber-500); font-size: 14px; }
  footer.alt a { color: var(--color-timber-300); }
</style>
</body></html>
