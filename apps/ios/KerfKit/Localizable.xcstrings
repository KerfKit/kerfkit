    "A light theme will be selectable once it’s ready; PDFs always print light.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Ein helles Design kommt, sobald es fertig ist; PDFs drucken immer hell."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "El tema claro llegará cuando esté listo; los PDF siempre se imprimen en claro."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Un thème clair arrivera dès qu'il sera prêt ; les PDF s'impriment toujours en clair."
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Il tema chiaro arriverà appena pronto; i PDF si stampano sempre in chiaro."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Açık tema hazır olunca seçilebilecek; PDF her zaman açık temada."
          }
        }
      }
    },
    "About": {
