    "%@ doesn’t fit the sheet — check its size or the grain lock." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ passt nicht auf die Platte — prüf die Maße oder die Maserungs-Sperre."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ no cabe en el tablero — revisa sus medidas o el bloqueo de veta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ ne rentre pas dans le panneau — vérifie ses dimensions ou le blocage du fil."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ non entra nel pannello — controlla le misure o il blocco venatura."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ levhaya sığmıyor — ölçüleri ya da damar kilidini kontrol et."
