    "One payment. No subscription, no renewals — like a tool: buy once, use forever." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine Zahlung. Kein Abo, keine Verlängerung — wie Werkzeug: einmal kaufen, immer nutzen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un solo pago. Sin suscripción, sin renovaciones — como una herramienta: la compras una vez y es tuya."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un seul paiement. Pas d'abonnement, pas de renouvellement — comme un outil : on l'achète une fois, on le garde."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un solo pagamento. Niente abbonamenti, niente rinnovi — come un attrezzo: lo compri una volta, è tuo."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tek ödeme. Abonelik yok, yenileme yok — alet gibi: bir kez al, hep kullan."
          }
        }
      }
    },
    "Or start with a ready-made sample —\nsee a cut plan right away." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oder starte mit einem fertigen Beispiel —\nund sieh sofort einen Schnittplan."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O empieza con un ejemplo ya montado —\ny ve un plan de corte al momento."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ou pars d'un exemple tout prêt —\net vois un plan de coupe tout de suite."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oppure parti da un esempio già pronto —\ne vedi subito un piano di taglio."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "İstersen hazır örnek projeyle başla —\nkesim planını hemen gör."
          }
        }
      }
    },
