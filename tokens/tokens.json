{
  "$description": "Kerf design tokens — DTCG 2025.10. Tek kaynak: buradan tokens.css (web) ve ColorTokens.swift/xcassets (iOS) uretilir. Build kurali: text.*/bg.* ciftleri WCAG AA kontrast testinden gecmeden build yesermez.",
  "color": {
    "timber": {
      "950": { "$type": "color", "$value": "#141210" },
      "900": { "$type": "color", "$value": "#1C1917" },
      "800": { "$type": "color", "$value": "#292524" },
      "700": { "$type": "color", "$value": "#44403C" },
      "500": { "$type": "color", "$value": "#78716C" },
      "300": { "$type": "color", "$value": "#A8A29E" },
      "200": { "$type": "color", "$value": "#E7E5E4" },
      "100": { "$type": "color", "$value": "#F5F0E6" },
      "50":  { "$type": "color", "$value": "#FAF8F5" }
    },
    "amber": {
      "400": { "$type": "color", "$value": "#FBBF24" },
      "500": { "$type": "color", "$value": "#F59E0B" },
      "600": { "$type": "color", "$value": "#D97706" },
      "700": { "$type": "color", "$value": "#B45309" },
      "800": { "$type": "color", "$value": "#92400E" }
    },
    "walnut": { "600": { "$type": "color", "$value": "#8A5A2B", "$description": "YALNIZ yuzey/dekor; on-plan YASAK (3.0:1)" } },
    "oak":    { "500": { "$type": "color", "$value": "#C9A227" } },
    "green":  { "500": { "$type": "color", "$value": "#34D399" }, "700": { "$type": "color", "$value": "#047857" } },
    "red":    { "500": { "$type": "color", "$value": "#F87171" }, "700": { "$type": "color", "$value": "#B91C1C" } },
    "blue":   { "500": { "$type": "color", "$value": "#60A5FA" }, "700": { "$type": "color", "$value": "#1D4ED8" } },

    "bg": {
      "canvas":  { "$type": "color", "$value": "{color.timber.50}",  "$extensions": { "mode": { "dark": "{color.timber.950}" } } },
      "surface": { "$type": "color", "$value": "#FFFFFF",            "$extensions": { "mode": { "dark": "{color.timber.900}" } } },
      "raised":  { "$type": "color", "$value": "{color.timber.200}", "$extensions": { "mode": { "dark": "{color.timber.800}" } } }
    },
    "text": {
      "primary":   { "$type": "color", "$value": "{color.timber.900}", "$extensions": { "mode": { "dark": "{color.timber.100}" } } },
      "secondary": { "$type": "color", "$value": "#57534E",            "$extensions": { "mode": { "dark": "{color.timber.300}" } } },
      "onAccent":  { "$type": "color", "$value": "{color.timber.950}" }
    },
    "accent": {
      "default": { "$type": "color", "$value": "{color.amber.700}", "$extensions": { "mode": { "dark": "{color.amber.500}" } } },
      "pressed": { "$type": "color", "$value": "{color.amber.800}", "$extensions": { "mode": { "dark": "{color.amber.600}" } } },
      "bright":  { "$type": "color", "$value": "{color.amber.600}", "$extensions": { "mode": { "dark": "{color.amber.400}" } } }
    },
    "border":  { "$type": "color", "$value": "#D6D3D1", "$extensions": { "mode": { "dark": "{color.timber.700}" } } },
    "success": { "$type": "color", "$value": "{color.green.700}", "$extensions": { "mode": { "dark": "{color.green.500}" } } },
    "danger":  { "$type": "color", "$value": "{color.red.700}",   "$extensions": { "mode": { "dark": "{color.red.500}" } } },
    "info":    { "$type": "color", "$value": "{color.blue.700}",  "$extensions": { "mode": { "dark": "{color.blue.500}" } } },
    "diagram": {
      "sheetBg":   { "$type": "color", "$value": "#FFFFFF", "$extensions": { "mode": { "dark": "{color.timber.800}" } } },
      "kerfLine":  { "$type": "color", "$value": "{color.amber.700}" },
      "material1": { "$type": "color", "$value": "#E8C89E" },
      "material2": { "$type": "color", "$value": "#B7CDB0" },
      "material3": { "$type": "color", "$value": "#AFC3D9" },
      "material4": { "$type": "color", "$value": "#D9B8C4" },
      "wasteHatch": { "$type": "color", "$value": "{color.timber.500}" }
    }
  },
  "space": {
    "100": { "$type": "dimension", "$value": "4px" },
    "200": { "$type": "dimension", "$value": "8px" },
    "300": { "$type": "dimension", "$value": "12px" },
    "400": { "$type": "dimension", "$value": "16px" },
    "500": { "$type": "dimension", "$value": "24px" },
    "600": { "$type": "dimension", "$value": "32px" },
    "700": { "$type": "dimension", "$value": "48px" }
  },
  "radius": {
    "control": { "$type": "dimension", "$value": "8px" },
    "card":    { "$type": "dimension", "$value": "12px" },
    "panel":   { "$type": "dimension", "$value": "16px" }
  },
  "size": {
    "touch":         { "$type": "dimension", "$value": "44px" },
    "touchWorkshop": { "$type": "dimension", "$value": "60px" }
  },
  "font": {
    "size": {
      "display":  { "$type": "dimension", "$value": "34px" },
      "title":    { "$type": "dimension", "$value": "28px" },
      "headline": { "$type": "dimension", "$value": "22px" },
      "body":     { "$type": "dimension", "$value": "17px" },
      "callout":  { "$type": "dimension", "$value": "15px" },
      "caption":  { "$type": "dimension", "$value": "13px" }
    }
  },
  "motion": {
    "micro": { "$type": "duration", "$value": "150ms" },
    "panel": { "$type": "duration", "$value": "250ms" }
  }
}
